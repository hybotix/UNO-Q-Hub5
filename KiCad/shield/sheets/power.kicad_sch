  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; 3.3V LDO — AMS1117-3.3
  ;; IPC-2221B §6.3: Voltage regulators placed close to load.
  ;; IN from +5V_EXT (after bulk caps). OUT to +3V3 rail.
  ;; Max load: ESP32-S3 (~300mA) + ES8388 (~30mA) + level shifters (~20mA)
  ;; AMS1117 rated 800mA — adequate with margin.
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "AMS1117-3.3") (at 100 30 0) (unit 1)
    (property "Reference" "U4" (at 100 22 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "AMS1117-3.3" (at 100 20 0)
      (effects (font (size 1.27 1.27)))))

  ;; LDO input bypass — within 2mm of VIN pin on PCB
  (symbol (lib_id "C") (at 88 30 0) (unit 1)
    (property "Reference" "C3" (at 90 29 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R" (at 90 31 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
