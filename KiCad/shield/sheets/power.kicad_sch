  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; AUDIO POWER — AGND/DGND STAR POINT
  ;; IPC-2221B §6.2.4: Analog and digital grounds joined at single point
  ;; to prevent digital switching noise coupling into audio signal path.
  ;; Star point is physically at ES8388 U5 on PCB.
  ;; Net tie NT1 creates the schematic connection for ERC while allowing
  ;; separate copper pours that meet at one via.
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;

  ;; Audio AVDD filter — ferrite bead isolates analog supply from digital +3V3
  ;; 600Ω @ 100MHz ferrite passes DC but blocks HF switching noise
  (symbol (lib_id "FERRITE_BEAD") (at 130 75 0) (unit 1)
    (property "Reference" "FB1" (at 132 71 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "BLM15AX601SN1D 600R@100MHz" (at 130 79 0)
      (effects (font (size 1.27 1.27))))
    (property "MPN" "BLM15AX601SN1D" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 145 75 0) (unit 1)
    (property "Reference" "C6" (at 147 74 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R" (at 147 76 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 155 75 0) (unit 1)
    (property "Reference" "C7" (at 157 74 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R" (at 157 76 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; DESIGN NOTES — POWER
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (text "POWER ARCHITECTURE NOTES (IPC-2221B / IPC-2152):\n\n+5V_EXT RAIL (J4 barrel jack, 5.5/2.1mm, tip-positive):\n  - Feeds HUB75 panel direct (J1 pins 4,8,14,18) — NO LDO in path\n  - Feeds AMS1117-3.3 IN pin\n  - PCB trace: 1.5mm min (handles 3A per IPC-2152 at 1oz Cu, 10°C rise)\n  - Polygon pour preferred for +5V distribution to J1\n\n+3V3 RAIL (AMS1117-3.3 output):\n  - Supplies: ESP32-S3 (U1), ES8388 DVDD (U5), 74HCT245 x2 (U2/U3)\n  - Max load: ~400mA. AMS1117 rated 800mA — 2x margin OK\n  - PCB trace: 0.5mm min\n  - Polygon pour on inner power plane preferred\n\nAGND/DGND STAR TOPOLOGY:\n  - NT1 net tie: AGND and DGND join at single star point (U5 ES8388)\n  - PCB: separate AGND pour under U5 audio section, DGND pour everywhere else\n  - Both pours connect through single via or pad bridge at U5\n  - DO NOT route DGND traces through AGND pour region\n\nAUDIO AVDD FILTERING:\n  - FB1 (600Ω @ 100MHz) in series with +3V3 to ES8388 AVDD pin\n  - C6 10µF + C7 100nF bypass on AVDD side of FB1\n  - Creates isolated analog power island"
    (at 20 100 0)
    (effects (font (size 1.27 1.27)) (justify left top)))

  ;; ── Net labels (hierarchical port connections) ───────────────────────────
  (hierarchical_label "+5V_EXT"
    (shape output) (at 50 26 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  (hierarchical_label "+3V3"
    (shape output) (at 135 26 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  (hierarchical_label "DGND"
    (shape output) (at 100 80 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  (hierarchical_label "AGND"
    (shape output) (at 120 80 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  (hierarchical_label "+5V_EXT_HUB75"
    (shape output) (at 50 30 0)
    (effects (font (size 1.27 1.27)) (justify right)))
)
