  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; POWER ENTRY — +5V_EXT barrel jack
  ;; IPC-2221B: Power entry point clearly identified, fused where required.
  ;; This design relies on upstream supply limiting; no onboard fuse.
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "BARREL_JACK_5V") (at 30 30 0) (unit 1)
    (property "Reference" "J4" (at 30 20 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "+5V_EXT INPUT" (at 30 18 0)
      (effects (font (size 1.27 1.27)))))

  ;; PWR_FLAG on +5V_EXT (ERC: marks this net as a power source)
  (symbol (lib_id "PWR_FLAG") (at 50 26 0) (unit 1)
