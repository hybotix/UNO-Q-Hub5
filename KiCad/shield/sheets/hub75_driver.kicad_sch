  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; U2 — SN74HCT245 — RGB DATA + CLK + LAT
  ;; A-side (pins 2-9): 3.3V from ESP32-S3
  ;; B-side (pins 11-18): 5V to HUB75 connector
  ;; DIR (pin 1) = GND → A→B direction only (unidirectional output)
  ;; ~OE (pin 19) = GND → always enabled
  ;; VCC (pin 20) = +5V_EXT_HUB75 (NOT +3V3 — 74HCT inputs are 3.3V tolerant
  ;;                                 but outputs must be 5V for HUB75)
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "SN74HCT245") (at 80 45 0) (unit 1)
    (property "Reference" "U2" (at 80 29 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "SN74HCT245PW" (at 80 27 0)
      (effects (font (size 1.27 1.27)))))

  ;; U2 bypass cap — 100nF within 2mm of pin 20 (VCC) on PCB
  (symbol (lib_id "C") (at 65 32 0) (unit 1)
    (property "Reference" "C8" (at 67 31 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 67 33 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM155R71A104KA01D" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

