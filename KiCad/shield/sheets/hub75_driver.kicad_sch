  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; J1 — HUB75 2×8 IDC PANEL CONNECTOR
  ;; Signal flow: ESP32-S3 → U2/U3 level shift → J1 → flat cable → panel
  ;; GND pins 4, 8, 14, 16 provide return current paths for signal groups
  ;; Per IPC-2221B: connector ground pins must return to GND plane via
  ;; low-inductance vias — do NOT route GND pins to long traces
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "HUB75_IDC_2x8") (at 155 77 0) (unit 1)
    (property "Reference" "J1" (at 155 61 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "HUB75 2×8 IDC" (at 155 59 0)
      (effects (font (size 1.27 1.27)))))

