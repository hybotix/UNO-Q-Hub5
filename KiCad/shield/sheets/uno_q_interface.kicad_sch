  ;; J2 — SPI3 interface from UNO Q (STM32U585 master)
  ;; Signals: MOSI, MISO, SCK from JSPI header; CS_S3_MCU from JDIGITAL
  (symbol (lib_id "CONN_1x6") (at 60 50 0) (unit 1)
    (property "Reference" "J2" (at 60 40 0) (effects (font (size 1.27 1.27))))
    (property "Value" "UNO_SPI_MCU" (at 60 38 0) (effects (font (size 1.27 1.27)))))

  ;; J3 — Debug UART header (GPIO47 TX only)
  ;; Also serves as CS_S3_MPU breakout on carrier (GPIO0)
  ;; On shield: TX only (GPIO47), GND
  (symbol (lib_id "CONN_1x2") (at 60 80 0) (unit 1)
    (property "Reference" "J3" (at 60 74 0) (effects (font (size 1.27 1.27))))
    (property "Value" "UART_DEBUG_TX" (at 60 72 0) (effects (font (size 1.27 1.27)))))

  (hierarchical_label "SPI_MOSI"
