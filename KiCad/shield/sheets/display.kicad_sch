  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; J6 — 22-pin 0.5mm FPC Display Connector
  ;; Signal routing: S3 SPI2 → J6 → flat cable → 5" TFT module
  ;; Touch: GT911 on display module → I2C back through J6 → shared I2C bus
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "FPC_22PIN_DISPLAY") (at 100 80 0) (unit 1)
    (property "Reference" "J6" (at 100 62 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "5in_TFT_GT911" (at 100 60 0)
      (effects (font (size 1.27 1.27)))))

  ;;
  ;; JP1 — SPI mode select (0Ω jumper on LCD_CLK path)
  ;; Closed = 4-wire SPI (default, populated)
  ;; Open   = future QSPI path (DNP unless QSPI upgrade)
  ;;
  (symbol (lib_id "R_0R_JUMPER") (at 75 78 90) (unit 1)
    (property "Reference" "JP1" (at 75 74 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "0Ω SPI_CLK_SEL" (at 75 76 0)
      (effects (font (size 1.27 1.27)))))

