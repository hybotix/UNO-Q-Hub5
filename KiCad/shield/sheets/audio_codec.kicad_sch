  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; POWER SECTION — AVDD filtering and AGND/DGND star point
  ;;
  ;; IPC-2221B §6.2.4: Analog and digital grounds joined at single star
  ;; point to prevent switching noise coupling into audio path.
  ;;
  ;; FB1 (600Ω@100MHz) passes DC but blocks HF switching noise from the
  ;; +3V3 digital rail before it reaches ES8388 AVDD.
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  ;; FB1 — Ferrite bead: +3V3 → AVDD
  ;; Murata BLM15AX601SN1D, 600Ω@100MHz, 500mA, 0402
  ;; IPC-2221B: place within 5mm of U5 AVDD pins on PCB

  ;; AVDD bypass — both caps on AVDD side of FB1 (analog island)
  ;; C6: 10µF — low-frequency bulk storage for DAC transients
  ;; C7: 100nF — high-frequency bypass for RF/EMI rejection
  ;; IPC-2221B: both within 2mm of U5 AVDD pins
  (symbol (lib_id "C") (at 80 26 0) (unit 1)
    (property "Reference" "C30" (at 82 25 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 82 27 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM21BR61A106KE18L" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 88 26 0) (unit 1)
    (property "Reference" "C31" (at 90 25 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 90 27 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM155R71A104KA01D" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; DVDD bypass — digital supply decoupling
  ;; C8: 10µF bulk, C9: 100nF HF — within 2mm of U5 DVDD pins
  (symbol (lib_id "C") (at 120 26 0) (unit 1)
    (property "Reference" "C32" (at 122 25 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 122 27 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM21BR61A106KE18L" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 128 26 0) (unit 1)
    (property "Reference" "C33" (at 130 25 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 130 27 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM155R71A104KA01D" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; VMID bypass — 2.2µF to AGND
  ;; ES8388 datasheet: VMID pin requires bypass cap for reference stability
  (symbol (lib_id "C") (at 60 50 0) (unit 1)
    (property "Reference" "C34" (at 62 49 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "2.2µF 10V X5R 0402" (at 62 51 0)
