    ;; ── ES8388 24-bit Stereo Audio Codec ────────────────────────────────────
    ;; LQFP-48, 7×7mm, 0.5mm pitch
    ;; IEEE 315: power pins top/bottom, signal flow left→right
    ;; AVDD/AGND: analog supply — must be filtered from DVDD/DGND
    ;; I2C address: 0x10 (ADDR=GND) or 0x11 (ADDR=VDD) — use 0x10
