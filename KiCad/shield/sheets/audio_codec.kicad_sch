  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; DAC OUTPUT PATH
  ;;
  ;; ES8388 LOUT1/ROUT1 → DC-blocking caps → J_OUT header
  ;;
  ;; DC-blocking caps: 10µF removes DC bias from DAC outputs.
  ;; Calculated: f_-3dB = 1/(2π×R_load×C) = 1/(2π×10k×10µF) = 1.6Hz
  ;; Well below 20Hz — negligible LF rolloff. 10µF is correct.
  ;;
  ;; Load resistor: 10kΩ each channel to GND provides defined impedance.
  ;; Prevents floating output when no load connected.
  ;; Line-level output impedance: ~600Ω (ES8388 internal) + 0 external = OK
  ;;
  ;; LOUT2/ROUT2: no-connect — second output pair not used on this board
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  ;; Left channel DC-blocking cap
  (symbol (lib_id "C") (at 145 70 0) (unit 1)
    (property "Reference" "C12" (at 147 69 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 147 71 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM21BR61A106KE18L" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; Right channel DC-blocking cap
  (symbol (lib_id "C") (at 145 78 0) (unit 1)
    (property "Reference" "C13" (at 147 77 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 147 79 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM21BR61A106KE18L" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; Left channel load resistor — 10kΩ to AGND
  (symbol (lib_id "R") (at 158 74 0) (unit 1)
    (property "Reference" "R30" (at 160 74 90)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10kΩ 1% 0402" (at 158 74 90)
      (effects (font (size 1.27 1.27))))
    (property "MPN" "RC0402FR-0710KL" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; Right channel load resistor — 10kΩ to AGND
  (symbol (lib_id "R") (at 158 82 0) (unit 1)
    (property "Reference" "R31" (at 160 82 90)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10kΩ 1% 0402" (at 158 82 90)
      (effects (font (size 1.27 1.27))))
    (property "MPN" "RC0402FR-0710KL" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;; J_OUT — Stereo line-out header (1×4, 2.54mm)
  ;; Pin 1: L_OUT  — left channel (after DC-block cap)
  ;; Pin 2: R_OUT  — right channel (after DC-block cap)
  ;; Pin 3: GND    — digital ground reference
  ;; Pin 4: AGND   — analog ground (star point) — connect separately in cable
  (symbol (lib_id "CONN_1x4_AUDIO") (at 180 78 0) (unit 1)
    (property "Reference" "J_OUT" (at 180 68 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "LINE_OUT_STEREO" (at 180 66 0)
      (effects (font (size 1.27 1.27)))))

  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; ADC INPUT PATH — DIGITAL MICROPHONE
  ;;
  ;; Digital mic (PDM/I2S) connects to J_MIC header.
  ;; Data and CLK from mic go directly to ES8388 LINPUT1/RINPUT1.
  ;; ES8388 ADC processes digital mic data — no analog mic path needed.
  ;;
  ;; Compatible mics: INMP441, SPH0645, MP34DT01, or any I2S/PDM mic
  ;; Header supplies +3V3 and GND for mic power.
  ;;
  ;; LINPUT2/RINPUT2: no-connect — second ADC input pair unused
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  ;; J_MIC — Digital mic header (1×4, 2.54mm)
  ;; Pin 1: +3V3  — mic VCC (100mA max, from +3V3 rail)
  ;; Pin 2: GND   — mic ground
  ;; Pin 3: DATA  — I2S/PDM data from mic to ES8388 LINPUT1
  ;; Pin 4: CLK   — I2S clock or PDM clock from ES8388 to mic
  (symbol (lib_id "CONN_1x4_MIC") (at 180 100 0) (unit 1)
    (property "Reference" "J_MIC" (at 180 90 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "PDM_I2S_MIC_IN" (at 180 88 0)
      (effects (font (size 1.27 1.27)))))

  ;; Mic VCC decoupling — 10µF + 100nF at mic header
  ;; Digital mic power is sensitive — local bypassing prevents
  ;; power-supply noise coupling into the mic data stream
  (symbol (lib_id "C") (at 168 88 0) (unit 1)
    (property "Reference" "C36" (at 170 87 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 170 89 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM21BR61A106KE18L" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 168 92 0) (unit 1)
    (property "Reference" "C37" (at 170 91 0)
      (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 170 93 0)
      (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide))
    (property "MPN" "GRM155R71A104KA01D" (at 0 0 0)
      (effects (font (size 1.27 1.27)) hide)))

  ;;
  ;; ── Hierarchical port connections ─────────────────────────────────────────
  ;;
  ;; Power inputs (from power sheet)
  (hierarchical_label "+3V3"
    (shape power_in) (at 45 26 0)
    (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "AGND"
    (shape power_in) (at 95 58 180)
    (effects (font (size 1.27 1.27)) (justify left)))
  (hierarchical_label "DGND"
    (shape power_in) (at 105 58 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  ;; I2S inputs from ESP32-S3 (S3 is I2S master)
  (hierarchical_label "I2S_BCLK"
    (shape input) (at 50 65 0)
    (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "I2S_LRCLK"
    (shape input) (at 50 69 0)
    (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "I2S_DOUT"
    (shape input) (at 50 73 0)
    (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "I2S_DIN"
    (shape output) (at 50 77 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  ;; I2C control from ESP32-S3 (shared bus, ES8388 at 0x10)
  (hierarchical_label "CODEC_SDA"
    (shape bidirectional) (at 50 85 0)
    (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "CODEC_SCL"
    (shape input) (at 50 89 0)
    (effects (font (size 1.27 1.27)) (justify right)))

  ;;
  ;; ── Design notes ──────────────────────────────────────────────────────────
  ;;
  (text "ES8388 AUDIO CODEC DESIGN NOTES:\n\nI2S MASTER/SLAVE CONFIGURATION:\n  ESP32-S3 is I2S MASTER: provides BCLK, LRCLK, and DACDAT (GPIO7).\n  ES8388 is I2S SLAVE: receives clock, sends ADCDAT back (GPIO15).\n  MCLK: ES8388 can generate its own MCLK internally — tie MCLK pin NC\n  or provide from S3 if needed. Default: ES8388 auto-generates from BCLK.\n  Sample rate: up to 96kHz (BCLK = 64×Fs = 6.144MHz at 96kHz).\n\nI2C ADDRESS:\n  CSB/ADDR (pin 7) tied to AGND via R3 (0Ω) → I2C address 0x10.\n  Alternate: tie CSB to AVDD → address 0x11. Rework R3 if needed.\n  Shared bus with GT911 (address 0x5D). No conflict.\n\nAGND / DGND STAR POINT (IPC-2221B §6.2.4):\n  NT1 net tie joins AGND and DGND at a SINGLE point at U5.\n  PCB implementation: separate copper pours meeting at one via under U5.\n  AGND pour: covers only U5, C6, C7, C12, C13, C15, C16, R30, R31, J_OUT.\n  DGND pour: all other components.\n  DO NOT route digital signal traces over the AGND pour region.\n  DO NOT connect AGND to DGND anywhere except at NT1 (star point).\n\nAVDD FILTERING (FB1 ferrite bead):\n  BLM15AX601SN1D: 600Ω @ 100MHz, DC resistance < 0.5Ω, rated 500mA.\n  ES8388 AVDD current: < 30mA. Well within FB1 rating.\n  Voltage drop at 30mA: 30mA × 0.5Ω = 15mV. Negligible.\n  FB1 must be placed within 5mm of U5 AVDD pins on PCB.\n  C6 (10µF) + C7 (100nF) on AVDD side of FB1 — analog island.\n\nDC-BLOCKING CAPACITORS (C12, C13):\n  Value: 10µF X5R 0805\n  f_-3dB = 1/(2π × R_load × C) = 1/(2π × 10kΩ × 10µF) ≈ 1.6 Hz\n  Rolloff well below 20Hz audio band — no audible LF effect.\n  Polarity: positive terminal toward ES8388 output (DAC output has\n  positive DC bias). Mark polarity on silkscreen.\n  X5R dielectric: stable over audio temperature range (-40 to +85°C).\n  Do NOT use X7R for audio DC-blocking — capacitance varies with DC bias.\n\nLOAD RESISTORS (R30, R31):\n  10kΩ to AGND on each channel after DC-blocking cap.\n  Defines output impedance for unloaded condition.\n  Without load resistor, ES8388 output may ring on cable capacitance.\n  10kΩ is a reasonable compromise: minimal current, defined impedance.\n\nDIGITAL MICROPHONE INPUT (J_MIC):\n  Compatible: INMP441, SPH0645, MP34DT01, or any I2S/PDM mic module.\n  DATA (pin 3) → ES8388 LINPUT1 (pin 34) — left channel ADC input.\n  CLK (pin 4) ← ES8388 provides bit clock to mic.\n  Stereo mics: LINPUT1 = left, RINPUT1 = right. Use L/R select pin on mic.\n  LINPUT2/RINPUT2: no-connect markers on U5 (second ADC input unused).\n\nHEADPHONE OUTPUTS (HPOUT_L, HPOUT_R):\n  LOUT2/ROUT2 and HPOUT pins: no-connect on this board.\n  No headphone amplifier populated — line-level only.\n  If headphone output needed in future: add TPA6133A2 amp after J_OUT.\n\nPCB LAYOUT PRIORITY (IPC-2221B):\n  1. Place U5 first. Establish AGND pour boundary.\n  2. Place FB1 within 5mm of U5 AVDD pins.\n  3. Place C6/C7 on AVDD side of FB1, within 2mm of U5 AVDD.\n  4. Place C8/C9 within 2mm of U5 DVDD pins.\n  5. Place C12/C13 on output side, as close to J_OUT as possible.\n  6. Route all audio traces over AGND pour only.\n  7. Keep I2S traces (BCLK, LRCLK) away from audio output traces.\n  8. NT1 star point: single via connecting AGND pour to DGND plane."
    (at 20 125 0)
    (effects (font (size 1.27 1.27)) (justify left top)))
)
