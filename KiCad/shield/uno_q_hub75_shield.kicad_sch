  ;; ═══════════════════════════════════════════════════
  ;; DESIGN NOTES
  ;; ═══════════════════════════════════════════════════
  (text "POWER: +5V_EXT (J4 barrel jack) feeds HUB75 panel directly.\nAMS1117-3.3 (U4) derives 3V3 for ESP32-S3 and ES8388.\nUNO Q shield headers carry logic signals only."
    (at 20 218 0) (effects (font (size 1.5 1.5))))
  (text "SPI: CS_S3_MCU (J2 pin5) = STM32U585. CS_S3_MPU (J3 pin1) = QRB2210.\nShared MOSI/MISO/SCK bus. ESP32-S3 is master-agnostic SPI slave.\nSoftware must ensure only one master drives bus at a time."
    (at 20 228 0) (effects (font (size 1.5 1.5))))
  (text "I2S AUDIO (ES8388 24-bit codec):\nS3 GPIO5=BCLK, GPIO6=LRCLK, GPIO7=DOUT(DAC), GPIO15=DIN(ADC)\nS3 GPIO8=I2C_SDA, GPIO9=I2C_SCL (codec control)\nLOUT1/ROUT1 -> J6 line out header (L, R, GND, AGND)\nLINPUT1/RINPUT1 <- J7 PDM/I2S mic header (VCC, GND, DATA, CLK)\n1k I2C pullup resistors R3/R4 to +3V3.\n10uF DC-blocking caps on all audio outputs."
    (at 20 238 0) (effects (font (size 1.5 1.5))))
  (text "HUB75 LEVEL SHIFTERS:\nU2 (74HCT245): R1,G1,B1,R2,G2,B2,CLK,LAT - 3.3V->5V\nU3 (74HCT245): ADDR_A-E, OE - 3.3V->5V\nDIR=GND (A->B), ~OE=GND (always enabled)"
    (at 20 258 0) (effects (font (size 1.5 1.5))))
  (text "QWIIC: J8+J9 daisy-chain. STM32U585 I2C SDA/SCL. 4k7 pullups R5/R6 to +3V3.\nGROVE: J10=I2C, J11=UART, J12=SPI, J13=Digital, J14=Analog. All STM32U585 3.3V."
    (at 20 272 0) (effects (font (size 1.5 1.5))))

