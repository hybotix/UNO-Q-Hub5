    (path "/J4" (reference "J4") (unit 1) (value "PWR_5V_EXT") (footprint "Connector_BarrelJack:BarrelJack_CUI_PJ-102AH_Horizontal"))
    (path "/C1" (reference "C1") (unit 1) (value "10uF") (footprint "Capacitor_SMD:C_0805_2012Metric"))
    (path "/C2" (reference "C2") (unit 1) (value "10uF") (footprint "Capacitor_SMD:C_0805_2012Metric"))
    (path "/C3" (reference "C3") (unit 1) (value "100nF") (footprint "Capacitor_SMD:C_0402_1005Metric"))
    (path "/C4" (reference "C4") (unit 1) (value "10uF") (footprint "Capacitor_SMD:C_0805_2012Metric"))
    (path "/C5" (reference "C5") (unit 1) (value "100nF") (footprint "Capacitor_SMD:C_0402_1005Metric"))
    (path "/C6" (reference "C6") (unit 1) (value "100nF") (footprint "Capacitor_SMD:C_0402_1005Metric"))
    (path "/R1" (reference "R1") (unit 1) (value "10k") (footprint "Resistor_SMD:R_0402_1005Metric"))
    (path "/R2" (reference "R2") (unit 1) (value "330R") (footprint "Resistor_SMD:R_0402_1005Metric"))
    (path "/D1" (reference "D1") (unit 1) (value "PWR_LED") (footprint "LED_SMD:LED_0402_1005Metric"))
  )
