  ;; ════════════════════════════════════════════════════════════════════════════
  ;; DESIGN NOTES
  ;; ════════════════════════════════════════════════════════════════════════════

  (text "POWER ARCHITECTURE:\n+5V_EXT (J4 barrel jack) feeds HUB75 panel directly.\nAMS1117-3.3 (U4) derives 3.3V for ESP32-S3.\nUNO Q shield headers carry logic signals only.\nDo NOT connect UNO Q 5V pin to +5V_EXT rail."
    (at 20 220 0) (effects (font (size 1.5 1.5))))

  (text "SPI ARBITRATION:\nCS_MCU (J2 pin5) = STM32U585 chip select.\nCS_MPU (J3 pin1) = QRB2210 chip select.\nSPI bus (MOSI/MISO/SCK) is shared.\nESP32-S3 is SPI slave only - master-agnostic.\nSoftware must ensure only one master active."
    (at 20 235 0) (effects (font (size 1.5 1.5))))

  (text "LEVEL SHIFTING:\nU2 (74HCT245): RGB data (R1,G1,B1,R2,G2,B2) + CLK + LAT\nU3 (74HCT245): Address lines (A-E) + OE\nDIR pin tied LOW (A-to-B, 3.3V→5V direction)\n~OE pin tied LOW (always enabled)"
    (at 20 250 0) (effects (font (size 1.5 1.5))))

  (text "HUB75 PANEL POWER:\nConnect +5V_EXT and GND directly to panel power connector.\nDo NOT power panel from shield logic rails.\nTypical 64x32 panel: 3-4A at 5V full brightness."
    (at 20 265 0) (effects (font (size 1.5 1.5))))

  (text "PROGRAMMING ESP32-S3:\nNative USB (GPIO19/20) exposed via USB-C connector on shield.\nFlash via esptool or PlatformIO over USB-CDC.\nNo separate USB-UART adapter required."
    (at 20 280 0) (effects (font (size 1.5 1.5))))

  (symbol_instances
    (path "/U1" (reference "U1") (unit 1) (value "ESP32-S3-MINI-1") (footprint "RF_Module:ESP32-S3-MINI-1"))
    (path "/U2" (reference "U2") (unit 1) (value "74HCT245") (footprint "Package_SO:SOIC-20_7.5x12.8mm_P1.27mm"))
    (path "/U3" (reference "U3") (unit 1) (value "74HCT245") (footprint "Package_SO:SOIC-20_7.5x12.8mm_P1.27mm"))
    (path "/U4" (reference "U4") (unit 1) (value "AMS1117-3.3") (footprint "Package_TO_SOT_SMD:SOT-223-3_TabPin2"))
    (path "/J1" (reference "J1") (unit 1) (value "HUB75") (footprint "Connector_IDC:IDC-Header_2x08_P2.54mm_Vertical"))
    (path "/J2" (reference "J2") (unit 1) (value "UNO_SPI_HDR") (footprint "Connector_PinHeader_2.54mm:PinHeader_1x06_P2.54mm_Vertical"))
