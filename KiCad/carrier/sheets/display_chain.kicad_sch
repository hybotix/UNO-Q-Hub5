  (symbol (lib_id "LT8618SX") (at 150 70 0) (unit 1)
    (property "Reference" "U_HDMI" (at 150 44 0) (effects (font (size 1.27 1.27))))
    (property "Value" "LT8618SX" (at 150 42 0) (effects (font (size 1.27 1.27)))))

  ;; LT8618SX power decoupling (all 3V3 rails)
  (symbol (lib_id "C") (at 135 46 0) (unit 1)
    (property "Reference" "C_H2" (at 137 45 0) (effects (font (size 1.27 1.27))))
    (property "Value" "10µF 10V X5R 0805" (at 137 47 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0805_2012Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 143 46 0) (unit 1)
    (property "Reference" "C_H3" (at 145 45 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 145 47 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 151 46 0) (unit 1)
    (property "Reference" "C_H4" (at 153 45 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 153 47 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  ;; TMDS output AC coupling caps (100nF each, on all TMDS pairs)
  ;; Required for HDMI compliance — AC coupled output
  (symbol (lib_id "C") (at 185 56 0) (unit 1)
    (property "Reference" "C_H5" (at 187 55 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 50V X7R 0402" (at 187 57 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 185 60 0) (unit 1)
    (property "Reference" "C_H6" (at 187 59 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 50V X7R 0402" (at 187 61 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 185 64 0) (unit 1)
    (property "Reference" "C_H7" (at 187 63 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 50V X7R 0402" (at 187 65 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  (symbol (lib_id "C") (at 185 68 0) (unit 1)
    (property "Reference" "C_H8" (at 187 67 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 50V X7R 0402" (at 187 69 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  ;; HPD pullup — 1kΩ to +5V (HDMI spec: HPD is 5V signal)
  (symbol (lib_id "R") (at 200 84 0) (unit 1)
    (property "Reference" "R_H1" (at 202 84 90) (effects (font (size 1.27 1.27))))
    (property "Value" "1kΩ 1% 0402" (at 200 84 90) (effects (font (size 1.27 1.27)))))

  ;; DDC pullups — 1kΩ each (DDC is I2C at 100kHz over HDMI)
  (symbol (lib_id "R") (at 200 88 0) (unit 1)
    (property "Reference" "R_H2" (at 202 88 90) (effects (font (size 1.27 1.27))))
    (property "Value" "1kΩ 1% 0402" (at 200 88 90) (effects (font (size 1.27 1.27)))))

  (symbol (lib_id "R") (at 200 92 0) (unit 1)
    (property "Reference" "R_H3" (at 202 92 90) (effects (font (size 1.27 1.27))))
    (property "Value" "1kΩ 1% 0402" (at 200 92 90) (effects (font (size 1.27 1.27)))))

  ;;
  ;; J_HDMI — Micro-HDMI Type D receptacle
  ;; Molex 47151-2001 (horizontal SMD, board edge mount)
  ;; RPi5 compatible: standard micro-HDMI to full HDMI cable works
  ;;
  (symbol (lib_id "MICRO_HDMI_D") (at 230 70 0) (unit 1)
    (property "Reference" "J_HDMI" (at 230 52 0) (effects (font (size 1.27 1.27))))
    (property "Value" "MICRO_HDMI_TypeD_RPi5" (at 230 50 0) (effects (font (size 1.27 1.27)))))

  ;;
  ;; J_DSI — 22-pin 0.5mm FPC, DSI display (RPi5 compatible)
  ;; CBTL04GP054 path B (SEL=HIGH)
  ;;
  (symbol (lib_id "FPC_22PIN_DSI") (at 80 120 0) (unit 1)
    (property "Reference" "J_DSI" (at 80 106 0) (effects (font (size 1.27 1.27))))
    (property "Value" "DSI_Display_RPi5" (at 80 104 0) (effects (font (size 1.27 1.27)))))

  ;;
  ;; ── Hierarchical port connections ─────────────────────────────────────────
  ;;
  ;; DSI input from JMEDIA (B2) via UNO Q mounting connectors sheet
  (hierarchical_label "DSI_CLK_P"
    (shape input) (at 40 64 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_CLK_N"
    (shape input) (at 40 68 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_D0_P"
    (shape input) (at 40 72 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_D0_N"
    (shape input) (at 40 76 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_D1_P"
    (shape input) (at 40 80 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_D1_N"
    (shape input) (at 40 84 0) (effects (font (size 1.27 1.27)) (justify right)))

  ;; Switch control from QRB2210 (via level shifter sheet)
  (hierarchical_label "DSI_SW_SEL"
    (shape input) (at 40 90 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "DSI_SW_OE"
    (shape input) (at 40 94 0) (effects (font (size 1.27 1.27)) (justify right)))

  ;; I2C for LT8618SX control (from STM32U585 or QRB2210)
  (hierarchical_label "HDMI_I2C_SCL"
    (shape input) (at 40 100 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "HDMI_I2C_SDA"
    (shape bidirectional) (at 40 104 0) (effects (font (size 1.27 1.27)) (justify right)))
  (hierarchical_label "HDMI_RST"
    (shape input) (at 40 108 0) (effects (font (size 1.27 1.27)) (justify right)))

  ;; Power
  (hierarchical_label "+3V3"
    (shape power_in) (at 130 44 180) (effects (font (size 1.27 1.27)) (justify left)))
  (hierarchical_label "+5V"
    (shape power_in) (at 200 80 180) (effects (font (size 1.27 1.27)) (justify left)))
  (hierarchical_label "DGND"
    (shape power_in) (at 130 52 180) (effects (font (size 1.27 1.27)) (justify left)))

  ;;
  ;; ── Design notes ──────────────────────────────────────────────────────────
  ;;
  (text "DISPLAY CHAIN NOTES:\n\nMICRO-HDMI TYPE D (J_HDMI — Molex 47151-2001):\n  19-pin, horizontal SMD, board-edge mount\n  RPi5 compatible: standard micro-HDMI to HDMI Type A cable works\n  TMDS AC coupling: 100nF 50V X7R on each pair (C_H5-H8, 8 total for 4 pairs)\n  HPD: 1kΩ pullup to +5V (HDMI spec requires 5V hot-plug detect)\n  DDC (EDID): 1kΩ pullups on SCL/SDA to +3V3 (DDC is I2C 100kHz)\n  CEC: connect with 27kΩ pullup to +3V3 (optional — can be NC)\n  Shell (pin 20): connect to GND via 1MΩ + 1nF RC (ESD per HDMI spec)\n\nLT8618SX HDMI TRANSMITTER:\n  I2C address: 0x75 (default). Control from STM32U585 or QRB2210.\n  Reset: active-LOW, 10ms pulse after power-up. GPIO from QRB2210.\n  PVDD (pixel VDD): separate 3V3 for cleaner pixel clock\n  TMDS_VDD: separate 3V3 for TMDS output stage\n  All 3V3 supplies: local 10µF + 100nF bypass, star ground at device\n  Firmware: Lontium reference driver available for Linux (RPi compatible)\n\nCBTL04GP054 MIPI SWITCH:\n  SEL=LOW  → Path A → LT8618SX → HDMI out\n  SEL=HIGH → Path B → J_DSI FPC → DSI display\n  ~OE=LOW: switch enabled. ~OE=HIGH: switch disabled (high-Z).\n  SEL and ~OE controlled by QRB2210 GPIO (1.8V) via TXS0108E level shifter\n  Only one path active at a time — firmware enforces this\n  VCC: 3V3. Propagation delay: <200ps. Supports up to 6Gbps per lane.\n\nDSI FPC (J_DSI — 22-pin 0.5mm Molex 503480-2200):\n  RPi5 camera/display compatible pinout\n  Carries DSI lanes D0, D1 from switch path B (2-lane DSI to display)\n  CCI (I2C): camera control interface — connect to STM32U585 I2C4\n  MCLK: optional master clock for camera modules\n  +3V3 and GND: supply to connected display/camera module\n\nIPC-2221B MIPI LAYOUT RULES:\n  100Ω differential impedance (adjust trace width for stackup)\n  P-N pair length matching: ≤0.5mm skew within pair\n  Lane-to-lane matching: ≤5mm\n  Route on inner layer where possible — avoid vias in MIPI paths\n  No copper fills within 3× trace width on adjacent layers\n  Reference to GND plane (Layer 2) — never route over power plane splits"
    (at 20 145 0) (effects (font (size 1.27 1.27)) (justify left top)))
)
