  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; U_SW — CBTL04GP054 MIPI DSI 4-LANE SWITCH
  ;; Input: QRB2210 DSI from JMEDIA (B2)
  ;; Output A (SEL=LOW):  LT8618SX → micro-HDMI out
  ;; Output B (SEL=HIGH): J_DSI FPC → RPi5 compatible DSI display
  ;; Only ONE output active at a time — software controlled
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "CBTL04GP054") (at 80 70 0) (unit 1)
    (property "Reference" "U_SW" (at 80 52 0) (effects (font (size 1.27 1.27))))
    (property "Value" "CBTL04GP054" (at 80 50 0) (effects (font (size 1.27 1.27)))))

  ;; CBTL04GP054 decoupling
  (symbol (lib_id "C") (at 68 56 0) (unit 1)
    (property "Reference" "C_H1" (at 70 55 0) (effects (font (size 1.27 1.27))))
    (property "Value" "100nF 10V X7R 0402" (at 70 57 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Capacitor_SMD:C_0402_1005Metric" (at 0 0 0) (effects (font (size 1.27 1.27)) hide)))

  ;;
  ;; U_HDMI — LT8618SX MIPI DSI → HDMI 2.0
