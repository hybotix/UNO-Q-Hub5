  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; ANTENNA SELECTION — 0Ω RESISTOR METHOD
  ;;
  ;; The MINI-1 (PCB antenna) and MINI-1U (U.FL) share the same footprint.
  ;; On-board, a 0Ω resistor R_ANT_PCB routes the RF pad to the module's
  ;; own PCB antenna (for MINI-1 fitted). R_ANT_EXT is DNP by default.
  ;;
  ;; To use external antenna:
  ;;   1. Swap module to MINI-1U
  ;;   2. DNP R_ANT_PCB, populate R_ANT_EXT (0Ω)
  ;;   3. Connect pigtail + external 2.4GHz antenna to J_ANT (U.FL)
  ;;
  ;; PCB topology:
  ;;   C6 RF pad ──┬── R_ANT_PCB (0Ω, default) ──▶ Module PCB ant (MINI-1)
  ;;               └── R_ANT_EXT (0Ω, DNP)     ──▶ J_ANT (U.FL) ──▶ external
  ;;
  ;; Note: ONLY ONE resistor populated at a time. Never both.
  ;; 50Ω characteristic impedance maintained in RF trace.
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  ;; R_ANT_PCB — populated by default (MINI-1 PCB antenna path)
  (symbol (lib_id "R") (at 145 65 90) (unit 1)
    (property "Reference" "R_ANT_PCB" (at 147 65 0) (effects (font (size 1.27 1.27))))
    (property "Value" "0Ω PCB_ANT (default)" (at 143 65 0) (effects (font (size 1.27 1.27)))))

  ;; R_ANT_EXT — DNP (not populated unless external antenna required)
  (symbol (lib_id "R") (at 145 73 90) (unit 1)
    (property "Reference" "R_ANT_EXT" (at 147 73 0) (effects (font (size 1.27 1.27))))
    (property "Value" "0Ω EXT_ANT DNP" (at 143 73 0) (effects (font (size 1.27 1.27)))))

  ;; J_ANT — U.FL connector for external antenna
  ;; DNP when MINI-1 (PCB antenna) is fitted; populate when MINI-1U is fitted
  (symbol (lib_id "U_FL_CONN") (at 165 73 0) (unit 1)
    (property "Reference" "J_ANT" (at 165 67 0) (effects (font (size 1.27 1.27))))
    (property "Value" "U.FL_Ext_2.4GHz" (at 165 65 0) (effects (font (size 1.27 1.27)))))

  ;;
  ;; ── USB-C for C6 debug (USB-Serial/JTAG) ─────────────────────────────────
  ;;
  (symbol (lib_id "USB_C_RECEPTACLE") (at 65 105 0) (unit 1)
    (property "Reference" "J_C6_USB" (at 65 97 0) (effects (font (size 1.27 1.27))))
    (property "Value" "C6_DEBUG_USB" (at 65 95 0) (effects (font (size 1.27 1.27)))))

  ;; CC resistors — 5.1kΩ each to GND
  (symbol (lib_id "R") (at 55 110 0) (unit 1)
