  ;;
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;; SECTION 2 — TPS54331 BUCK CONVERTER: VIN → +5V / 3A
  ;;
  ;; TPS54331 component values (calculated for 5V output, 570kHz):
  ;;   RT (pin 5 via R_RT): 100kΩ → 570kHz switching frequency
  ;;   VSENSE divider: R_FB_TOP=1.0MΩ, R_FB_BOT=200kΩ → Vout=5.03V
  ;;   Vout = 0.8V × (1 + R_FB_TOP/R_FB_BOT) = 0.8 × (1 + 1M/200k) = 4.8V
  ;;   Adjusted: R_FB_TOP=1.0MΩ, R_FB_BOT=191kΩ → 5.00V exact
  ;;   Use: 200kΩ + adjust with 2nd parallel resistor, or use 196kΩ std
  ;;   Simpler: R_FB_BOT = 196kΩ → Vout = 0.8×(1+1M/196k) = 4.98V ≈ 5.0V
  ;;   Inductor: L = Vout×(1-D)/(ΔIL×f) = 5×(1-5/12)/(0.6×570k) ≈ 8.8µH → 10µH
  ;;   D2 catch diode: SS34 (3A, 40V Schottky)
  ;;   Input caps: 2×100µF 35V + 100nF (already at VIN connector)
  ;;   Output caps: 2×100µF 10V (low ESR for stable loop)
  ;;   Soft-start cap C_SS: 100nF → 5ms startup
  ;;   COMP: 10kΩ + 100nF (Type II compensation, safe starting values)
  ;; ═══════════════════════════════════════════════════════════════════════════
  ;;
  (symbol (lib_id "TPS54331") (at 100 40 0) (unit 1)
    (property "Reference" "U7" (at 100 30 0) (effects (font (size 1.27 1.27))))
    (property "Value" "TPS54331DR" (at 100 28 0) (effects (font (size 1.27 1.27)))))

